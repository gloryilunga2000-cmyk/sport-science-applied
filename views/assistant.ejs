<%- include('partials/header') %>

<main style="max-width: 850px; margin: 20px auto; padding: 0 15px;">
    
    <div style="text-align: center; margin-bottom: 25px;">
        <h1 style="color: #1e293b; margin-bottom: 5px; font-size: 2.2rem;">Sport Science Research Engine</h1>
        <p style="color: #64748b; margin: 0; font-size: 1.1rem;">Full Workspace: Deep-dive into athletic literature and real-time physiological data maps.</p>
    </div>

    <div class="page-chat-container">
        <div class="chat-box" id="pageChatBox">
            <div class="message ai-message">
                <strong>Assistant:</strong> Welcome to your full research workspace. Ask me to break down comprehensive training blocks or analyze biomechanical concepts.
            </div>
        </div>

        <div class="loading-indicator" id="pageLoadingIndicator">
            <div class="dot"></div><div class="dot"></div><div class="dot"></div>
            <span style="margin-left: 8px; font-size: 0.9rem; color: #64748b;">Analyzing databases...</span>
        </div>

        <form class="input-area" id="pageChatForm">
            <input type="text" id="pageUserInput" placeholder="Type your deep research query here..." autocomplete="off" required>
            <button type="submit" id="pageSendBtn">Query Engine</button>
        </form>
    </div>

    <hr style="margin: 50px 0; border: 0; border-top: 2px dashed #cbd5e1;">

    <div style="text-align: center; margin-bottom: 20px;">
        <h2 style="color: #1e293b; margin-bottom: 5px;">Continuous Literature Feed</h2>
        <p style="color: #64748b; font-size: 0.95rem; margin: 0;">Scroll down to load more sports science journal briefs asynchronously.</p>
    </div>

    <div id="asyncFeedGrid" style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 40px;">
        <div class="feed-card">
            <span class="feed-journal">Sports Biomechanics (2026)</span>
            <h3 class="feed-title">Ground Reaction Force (GRF) Vector Stacking</h3>
            <p class="feed-summary">Recent vector maps confirm lateral force vectors during cutting maneuvers increase knee abduction moments by 22% if hip internal rotation is uncontrolled.</p>
        </div>
    </div>

    <div id="scrollLoader" style="text-align: center; padding: 20px; color: #94a3b8; font-size: 0.9rem; font-weight: bold;">
        <span>Scroll down to expand literature database...</span>
    </div>

</main>

<style>
    /* Chat layout styling coordinates */
    .page-chat-container { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05); display: flex; flex-direction: column; height: 420px; overflow: hidden; }
    .chat-box { flex: 1; padding: 25px; overflow-y: auto; background-color: #fafafa; display: flex; flex-direction: column; gap: 15px; }
    .message { padding: 14px 18px; border-radius: 10px; max-width: 85%; line-height: 1.5; font-size: 0.98rem; }
    .ai-message { background-color: #f1f5f9; color: #1e293b; align-self: flex-start; border-left: 4px solid #007BFF; white-space: pre-line; }
    .user-message { background-color: #1e293b; color: #ffffff; align-self: flex-end; }
    .input-area { display: flex; border-top: 1px solid #e2e8f0; padding: 15px; background: #ffffff; gap: 10px; }
    #pageUserInput { flex: 1; padding: 12px 16px; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 1rem; background-color: #f8fafc; outline: none; }
    #pageSendBtn { background-color: #007BFF; color: white; border: none; padding: 0 24px; border-radius: 8px; font-weight: 600; cursor: pointer; }
    
    .loading-indicator { display: none; align-items: center; padding: 10px 25px; background: #fafafa; }
    .dot { width: 8px; height: 8px; background-color: #94a3b8; border-radius: 50%; margin-right: 4px; animation: wave 1.3s infinite ease-in-out; }
    .dot:nth-child(2) { animation-delay: -1.1s; }
    .dot:nth-child(3) { animation-delay: -0.9s; }
    @keyframes wave { 0%, 60%, 100% { transform: translateY(0); } 30% { transform: translateY(-6px); } }

    /* 🌟 Async Feed Card Styling Elements 🌟 */
    .feed-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        padding: 24px;
        border-radius: 10px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
        border-left: 4px solid #1e293b;
        transition: transform 0.2s ease;
    }
    .feed-card:hover { transform: translateX(5px); border-left-color: #007BFF; }
    .feed-journal { font-size: 0.78rem; font-weight: bold; text-transform: uppercase; color: #007BFF; letter-spacing: 0.5px; }
    .feed-title { margin: 6px 0 10px 0; color: #1e293b; font-size: 1.25rem; }
    .feed-summary { margin: 0; color: #475569; font-size: 0.95rem; line-height: 1.5; }
</style>

<script>
    // --- CHAT LOGIC SUBSYSTEM WITH TYPING EFFECT ---
    const pageForm = document.getElementById('pageChatForm');
    const pageInput = document.getElementById('pageUserInput');
    const pageBox = document.getElementById('pageChatBox');
    const pageLoader = document.getElementById('pageLoadingIndicator');

    pageForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const textMessage = pageInput.value.trim();
        if(!textMessage) return;

        appendPageMessage(textMessage, 'user-message', 'You');
        pageInput.value = ''; 
        pageLoader.style.display = 'flex';
        pageBox.scrollTop = pageBox.scrollHeight;

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: textMessage })
            });
            const data = await response.json();
            pageLoader.style.display = 'none';

            if(data.reply) {
                appendPageMessage(data.reply, 'ai-message', 'Assistant');
            } else {
                appendPageMessage("The analysis engine timed out.", 'ai-message', 'System');
            }
        } catch (error) {
            pageLoader.style.display = 'none';
            appendPageMessage("Connection issue.", 'ai-message', 'System');
        }
        pageBox.scrollTop = pageBox.scrollHeight;
    });

    function appendPageMessage(text, className, sender) {
        const msgDiv = document.createElement('div');
        msgDiv.className = `message ${className}`;
        
        if (className === 'ai-message' && sender === 'Assistant') {
            msgDiv.innerHTML = `<strong>${sender}:</strong> <span class="page-typing-text"></span>`;
            pageBox.appendChild(msgDiv);
            const textSpan = msgDiv.querySelector('.page-typing-text');
            let index = 0;
            function typeWriter() {
                if (index < text.length) {
                    textSpan.innerHTML += text.charAt(index);
                    index++;
                    pageBox.scrollTop = pageBox.scrollHeight;
                    setTimeout(typeWriter, 12);
                }
            }
            typeWriter();
        } else {
            msgDiv.innerHTML = `<strong>${sender}:</strong> ${text}`;
            pageBox.appendChild(msgDiv);
        }
    }

    // --- 🌟 NEW: INFINITE ASYNC SCROLLING ENGINE 🌟 ---
    const feedGrid = document.getElementById('asyncFeedGrid');
    const scrollLoader = document.getElementById('scrollLoader');
    let isFetching = false;
    let fetchCount = 0;
    const maxFetches = 3; // Throttles infinity pool to save resource quota limits

    window.addEventListener('scroll', async () => {
        if (isFetching || fetchCount >= maxFetches) return;

        // Check if browser viewport window has neared the absolute bottom layout limit
        if ((window.innerHeight + window.scrollY) >= document.documentElement.scrollHeight - 100) {
            isFetching = true;
            scrollLoader.innerHTML = "Querying live database indexes...";

            try {
                // Silently call our custom asynchronous Express endpoint background worker
                const response = await fetch('/api/research-feeds');
                const researchItems = await response.json();
                
                // Slow down injection slightly for visual fluidity aesthetics
                setTimeout(() => {
                    researchItems.forEach(item => {
                        const card = document.createElement('div');
                        card.className = 'feed-card';
                        card.innerHTML = `
                            <span class="feed-journal">${item.journal}</span>
                            <h3 class="feed-title">${item.title}</h3>
                            <p class="feed-summary">${item.summary}</p>
                        `;
                        feedGrid.appendChild(card);
                    });

                    fetchCount++;
                    isFetching = false;
                    
                    if(fetchCount >= maxFetches) {
                        scrollLoader.innerHTML = "🏆 Local sport science data bank fully sync'd.";
                    } else {
                        scrollLoader.innerHTML = "Scroll down to expand literature database...";
                    }
                }, 800);

            } catch (error) {
                console.error("Async Fetch Failed:", error);
                scrollLoader.innerHTML = "Data link dropped. Retrying on next trigger...";
                isFetching = false;
            }
        }
    });
</script>

<%- include('partials/footer') %>
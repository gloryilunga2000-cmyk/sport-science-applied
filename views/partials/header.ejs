<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <style>
        /* 1. CLEAN GLOBAL STYLES */
        body { 
            font-family: Arial, sans-serif; 
            margin: 0; 
            padding: 0; 
            line-height: 1.6; 
            color: #333; 
            background-color: #ffffff;
        }
        
        /* 🌟 GLOBAL PAGE WIDTH CONFIGURATION: Standardized 1200px footprint across the app 🌟 */
        .wide-container, .global-page-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            box-sizing: border-box;
            width: 100%;
        }

        /* 2. SPECIFIC HEADER STYLES */
        .brand-header-stacked { 
            border-bottom: 2px solid #333; 
            padding: 30px 20px 25px 20px; 
            margin: 0 auto 30px auto; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            gap: 20px; 
            max-width: 1200px; 
            width: 100%;
            box-sizing: border-box;
        }
        
        .centered-logo-link {
            display: flex;
            align-items: center;
            text-decoration: none;
            justify-content: center;
        }

        .large-brand-logo {
            height: 160px;       
            width: auto;        
            max-width: 100%;    
            object-fit: contain;
            transition: transform 0.2s ease;
        }
        .large-brand-logo:hover {
            transform: scale(1.02);
        }

        /* 3. NAVIGATION LINKS ROW */
        .centered-nav-row {
            display: flex;
            justify-content: center;
            gap: 30px; 
        }
        .centered-nav-row a { 
            text-decoration: none; 
            color: #007BFF; 
            font-weight: bold; 
            transition: color 0.15s ease;
        }
        .centered-nav-row a:hover {
            color: #0056b3; 
        }

        /* 4. PRESERVING REUSEABLE STYLES */
        .hero { 
            background: #1e293b; 
            color: #fff; 
            padding: 45px; 
            border-radius: 12px; 
            margin: 20px auto 40px auto; 
            box-sizing: border-box;
        }
        .hero h1 { margin-top: 0; color: #38bdf8; font-size: 2.2rem; }
        
        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); 
            gap: 25px; 
            margin-top: 20px; 
        }
        
        .card { 
            border: 1px solid #ddd; 
            padding: 24px; 
            border-radius: 8px; 
            text-decoration: none; 
            color: inherit; 
            background: #ffffff;
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; 
        }
        .card:hover { 
            transform: translateY(-4px); 
            box-shadow: 0 6px 15px rgba(0,0,0,0.08); 
            border-color: #007BFF; 
        }
        .card h3 { margin-top: 0; color: #007BFF; font-size: 1.25rem; }
        .metric-list { background: #f4f4f4; padding: 20px; border-left: 5px solid #007BFF; list-style-type: square; margin: 15px 0; font-size: 1.05rem; }
        .back-link { display: inline-block; margin-bottom: 20px; color: #007BFF; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>

<header class="brand-header-stacked">
        <a href="/" class="centered-logo-link">
            <img src="/images/sport-science-logo.png" alt="Sport Science Applied Logo" class="large-brand-logo">
        </a>
        
        <nav class="centered-nav-row">
            <a href="/#home-top">Home</a>
            <a href="/#sports-section">Sport Codes</a>
            <a href="/#research-section">Research Engine</a> 
            <a href="/#booking-section">Book Consultation</a>
        </nav>
    </header>

    <div class="global-page-wrapper">